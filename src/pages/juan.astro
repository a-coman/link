---
/**
 * juan.astro : A FULLY CUSTOM Linktree page.
 * No YAML schema involved pure Astro + CSS.
 *
 * Use this as a template when you want complete design freedom
 * beyond what the YAML/template system offers.
 * 
 * You should always start with a BaseLayout component with a title and description.
 * 
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import { Icon } from 'astro-icon/components';
const title = "Juan Rodríguez";
const description = "Creative Director & Filmmaker";

---

<BaseLayout
  title={title}
  description={description}
  background="#080808"
  textColor="#f0ede6"
>
  <div class="page">
    <!-- ── Header ─────────────────────────────────────────── -->
    <header class="hero">
      <div class="avatar-ring">
        <div class="avatar-initials">JR</div>
      </div>
      <div class="hero-text">
        <h1 class="name">{title}</h1>
        <p class="role">{description}</p>
        <div class="socials">
          <a href="https://twitter.com/juan" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="social-btn">
            <Icon name="ph:x-logo" width={16} height={16} aria-hidden="true" />
          </a>
          <a href="https://instagram.com/juan" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-btn">
            <Icon name="ph:instagram-logo" width={16} height={16} aria-hidden="true" />
          </a>
          <a href="mailto:juan@studio.com" aria-label="Email" class="social-btn">
            <Icon name="ph:envelope-simple" width={16} height={16} aria-hidden="true" />
          </a>
        </div>
      </div>
    </header>

    <!-- ── Divider ─────────────────────────────────────────── -->
    <div class="rule"></div>

    <!-- ── Link Grid ──────────────────────────────────────── -->
    <section class="links-section" aria-label="Links">
      <a href="https://juan.studio" target="_blank" rel="noopener noreferrer" class="link-card featured">
        <span class="link-label">PORTFOLIO</span>
        <span class="link-card-title">View my Work</span>
        <span class="link-card-sub">Films · Photography · Direction</span>
        <span class="link-ext-icon" aria-hidden="true"><Icon name="ph:arrow-up-right" width={16} height={16} /></span>
      </a>

      <div class="link-pair">
        <a href="https://cal.com/juan" target="_blank" rel="noopener noreferrer" class="link-card half">
          <span class="link-label">CALENDAR</span>
          <span class="link-card-title">Book a Call</span>
        </a>
        <a href="https://vimeo.com/juan" target="_blank" rel="noopener noreferrer" class="link-card half">
          <span class="link-label">VIMEO</span>
          <span class="link-card-title">Short Films</span>
        </a>
      </div>

      <a href="https://studio.substack.com" target="_blank" rel="noopener noreferrer" class="link-card">
        <span class="link-label">NEWSLETTER</span>
        <span class="link-card-title">Notes on Craft</span>
        <span class="link-card-sub">Monthly reflections on filmmaking &amp; design</span>
        <span class="link-ext-icon" aria-hidden="true"><Icon name="ph:arrow-up-right" width={16} height={16} /></span>
      </a>

      <a href="https://shop.juan.studio" target="_blank" rel="noopener noreferrer" class="link-card">
        <span class="link-label">SHOP</span>
        <span class="link-card-title">Presets &amp; Templates</span>
        <span class="link-card-sub">Pro-grade tools for filmmakers</span>
        <span class="link-ext-icon" aria-hidden="true"><Icon name="ph:arrow-up-right" width={16} height={16} /></span>
      </a>
    </section>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 540px;
    width: 100%;
    margin: 0 auto;
    padding: clamp(1.5rem, 6vw, 3.5rem) clamp(1rem, 5vw, 1.25rem) clamp(3rem, 8vw, 5rem);
    min-width: 0;
  }

  /* ── Hero ─────────────────────────────────────── */
  .hero {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  .avatar-ring {
    flex-shrink: 0;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    border: 1.5px solid rgba(240, 237, 230, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  :global(html[data-theme="light"]) .avatar-ring {
    border-color: rgba(0, 0, 0, 0.15);
  }

  .avatar-initials {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: rgba(240, 237, 230, 0.7);
  }
  :global(html[data-theme="light"]) .avatar-initials {
    color: rgba(0, 0, 0, 0.7);
  }

  .hero-text {
    flex: 1;
    min-width: 0;
  }

  .name {
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-bottom: 0.2rem;
  }

  .role {
    font-size: 0.78rem;
    opacity: 0.45;
    letter-spacing: 0.02em;
    margin-bottom: 0.65rem;
  }

  .socials {
    display: flex;
    gap: 0.4rem;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border: 1px solid rgba(240, 237, 230, 0.12);
    color: inherit;
    opacity: 0.6;
    transition: opacity 0.18s, border-color 0.18s, transform 0.18s;
    text-decoration: none;
  }
  :global(html[data-theme="light"]) .social-btn {
    border-color: rgba(0, 0, 0, 0.12);
  }
  
  .social-btn:hover {
    opacity: 1;
    border-color: rgba(240, 237, 230, 0.35);
    transform: translateY(-2px);
  }
  :global(html[data-theme="light"]) .social-btn:hover {
    border-color: rgba(0, 0, 0, 0.35);
  }

  /* ── Rule ─────────────────────────────────────── */
  .rule {
    border-top: 1px solid rgba(240, 237, 230, 0.08);
    margin-bottom: 1.5rem;
  }
  :global(html[data-theme="light"]) .rule {
    border-color: rgba(0, 0, 0, 0.08);
  }

  /* ── Links ────────────────────────────────────── */
  .links-section {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .link-card {
    display: block;
    position: relative;
    padding: 1.1rem 1.15rem;
    border: 1px solid rgba(240, 237, 230, 0.1);
    background: rgba(240, 237, 230, 0.03);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.18s, background 0.18s, transform 0.18s;
    overflow: hidden;
    min-width: 0;
  }
  :global(html[data-theme="light"]) .link-card {
    border-color: rgba(0, 0, 0, 0.1);
    background: rgba(0, 0, 0, 0.03);
  }

  .link-card:hover {
    border-color: rgba(240, 237, 230, 0.28);
    background: rgba(240, 237, 230, 0.06);
    transform: translateY(-1px);
  }
  :global(html[data-theme="light"]) .link-card:hover {
    border-color: rgba(0, 0, 0, 0.28);
    background: rgba(0, 0, 0, 0.06);
  }

  .link-card.featured {
    border-color: rgba(240, 237, 230, 0.18);
    background: rgba(240, 237, 230, 0.06);
  }
  :global(html[data-theme="light"]) .link-card.featured {
    border-color: rgba(0, 0, 0, 0.18);
    background: rgba(0, 0, 0, 0.06);
  }

  .link-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.55rem;
  }

  .link-card.half {
    /* inherits from .link-card */
  }

  .link-label {
    display: block;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    opacity: 0.35;
    margin-bottom: 0.35rem;
  }

  .link-card-title {
    display: block;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .link-card-sub {
    display: block;
    font-size: 0.75rem;
    opacity: 0.45;
    margin-top: 0.3rem;
    letter-spacing: 0.01em;
  }

  .link-ext-icon {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-size: 1rem;
    opacity: 0.25;
    transition: opacity 0.18s, transform 0.18s;
    font-family: system-ui, sans-serif;
  }
  .link-card:hover .link-ext-icon {
    opacity: 0.7;
    transform: translate(2px, -2px);
  }

  /* ── Footer ───────────────────────────────────── */
  .page-footer {
    margin-top: 3rem;
  }

  .back-link {
    font-size: 0.75rem;
    opacity: 0.3;
    text-decoration: none;
    transition: opacity 0.18s;
  }
  .back-link:hover {
    opacity: 0.7;
  }

  @media (max-width: 400px) {
    .page {
      padding-inline: 0.9rem;
    }

    .hero {
      flex-direction: column;
      text-align: center;
    }
    .socials {
      justify-content: center;
    }
    .link-pair {
      grid-template-columns: 1fr;
    }
  }
</style>
