---
/**
 * index.astro — Home page / directory of all profiles.
 * Lists links to every generated profile page.
 */
import { getCollection } from 'astro:content';
import fs from 'node:fs/promises';
import path from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';

const profiles = await getCollection('profiles');

// Get content collection links
const allLinks = profiles.map(p => ({ id: p.id, name: p.data.name }));

// Dynamically scan for handcrafted pages in src/pages
const pagesDir = path.join(process.cwd(), 'src/pages');
const files = await fs.readdir(pagesDir);

for (const file of files) {
  if (file.endsWith('.astro') && file !== 'index.astro' && !file.startsWith('[')) {
    const id = file.replace(/\.astro$/, '');
    const content = await fs.readFile(path.join(pagesDir, file), 'utf-8');
    
    // Extract title from const title="..." or <BaseLayout title="...">
    const titleVarMatch = content.match(/const\s+title\s*=\s*["']([^"']+)["']/);
    const titleAttrMatch = content.match(/title=["']([^"']+)["']/);
    
    let name = id;
    if (titleVarMatch) {
      name = titleVarMatch[1];
    } else if (titleAttrMatch) {
      name = titleAttrMatch[1];
    }
    
    allLinks.push({ id, name });
  }
}

allLinks.sort((a, b) => a.name.localeCompare(b.name));
---

<BaseLayout title="Links" description="Directory of all pages">
  <div class="directory container-box container-pad">
    <header class="dir-header">
      <h1 class="dir-title">Links</h1>
      <p class="dir-sub text-sub">Directory of all pages</p>
    </header>
    <ul class="dir-list" role="list">
      {allLinks.map((p) => (
        <li>
          <a href={`/${p.id}`} class="dir-item card-interactive">
            <span class="dir-name">{p.name}</span>
            <span class="dir-slug text-sub">/{p.id}</span>
            <svg class="dir-arrow card-arrow" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
              <path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z" />
            </svg>
          </a>
        </li>
      ))}
    </ul>
    <p class="dir-hint">
      Add a <code>.yaml</code> file to <code>src/profiles/</code> to create a new template page.
      <br>
      Add a <code>.astro</code> file to <code>src/pages/</code> to create a new custom page.
    </p>
  </div>
</BaseLayout>

<style>
  .directory {
    /* managed by container-box and container-pad */
  }

  .dir-header {
    margin-bottom: 2.5rem;
  }

  .dir-title {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .dir-sub {
    margin-top: 0.4rem;
  }

  .dir-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .dir-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1rem;
    min-width: 0;
  }

  .dir-name {
    font-size: 0.9rem;
    font-weight: 500;
    flex: 1;
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .dir-slug {
    font-family: monospace;
    flex-shrink: 0;
  }

  /* dir-arrow styling managed by card-arrow */

  .dir-hint {
    margin-top: 2.5rem;
    font-size: 0.75rem;
    opacity: 0.3;
    line-height: 1.6;
  }
  .dir-hint code {
    font-family: monospace;
    background: var(--card-bg);
    padding: 0.1em 0.35em;
    border-radius: 2px;
  }

  @media (max-width: 420px) {
    .directory {
      padding-inline: 0.9rem;
    }

    .dir-item {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
    }

    .dir-slug {
      grid-column: 1 / 2;
    }

    .dir-arrow {
      grid-column: 2 / 3;
      grid-row: 1 / 3;
      justify-self: end;
    }
  }
</style>
