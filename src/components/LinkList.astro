---
/**
 * LinkList — renders a vertical list of styled link buttons.
 * Icons resolved via astro-icon (Phosphor set).
 */
import { Icon } from 'astro-icon/components';
import { resolveIcon } from '../utils/icons';

interface LinkItem {
  title: string;
  url: string;
  description?: string;
  icon?: string;
  newTab?: boolean;
}

interface Props {
  links: LinkItem[];
  buttonStyle?: 'sharp' | 'rounded' | 'pill';
}

const { links, buttonStyle = 'sharp' } = Astro.props;
---

<ul class={`link-list btn-${buttonStyle} stagger-list`} role="list">
  {links.map((link) => {
    const resolved = link.icon ? resolveIcon(link.icon) : null;
    const target = link.newTab !== false ? '_blank' : '_self';
    const rel    = link.newTab !== false ? 'noopener noreferrer' : undefined;
    return (
      <li>
        <a href={link.url} target={target} rel={rel} class="link-btn card-interactive">
          {resolved && (
            <span class="link-icon" aria-hidden="true">
              <Icon name={resolved.icon} width={16} height={16} />
            </span>
          )}
          <span class="link-copy">
            <span class="link-title">{link.title}</span>
            {link.description && (
              <span class="link-desc text-sub">{link.description}</span>
            )}
          </span>
          <span class="link-arrow card-arrow" aria-hidden="true">
            <Icon name="ph:arrow-right" width={11} height={11} />
          </span>
        </a>
      </li>
    );
  })}
</ul>

<style>
  .link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    width: 100%;
    max-width: 100%;
  }

  .link-list li {
    min-width: 0;
    width: 100%;
  }

  .link-btn {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.8rem;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
    padding: 0.9rem 1.1rem;
    position: relative;
    overflow: hidden;
  }

  /* Border-radius variants */
  .btn-sharp   .link-btn { border-radius: 0; }
  .btn-rounded .link-btn { border-radius: 5px; }
  .btn-pill    .link-btn { border-radius: 9999px; }

  .link-icon {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    opacity: 0.5;
    transition: opacity 0.25s ease;
  }

  .link-btn:hover .link-icon {
    opacity: 0.85;
  }

  .link-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.1rem;
    min-width: 0;
  }

  .link-title {
    font-family: var(--font-display, 'IBM Plex Mono', monospace);
    font-size: 0.84rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    line-height: 1.25;
  }

  .link-desc {
    font-family: var(--font-body, 'IBM Plex Sans', system-ui, sans-serif);
    /* opacity and size managed globally by .text-sub */
  }

  .link-arrow {
    display: inline-flex;
    align-items: center;
  }

  @media (max-width: 420px) {
    .link-btn {
      padding: 0.85rem 1rem;
      gap: 0.65rem;
    }

    .link-title {
      white-space: normal;
      overflow: visible;
      text-overflow: unset;
      overflow-wrap: anywhere;
    }
  }
</style>
