---
/**
 * LinkTemplate — the main template that renders a profile page from YAML data.
 * Orchestrates ProfileRow, LinkList, and text/divider blocks.
 */
import ProfileRow from "./ProfileRow.astro";
import LinkList from "./LinkList.astro";

interface Block {
  type: "profiles" | "links" | "text" | "divider";
  [key: string]: unknown;
}

interface Props {
  name: string;
  description?: string;
  buttonStyle?: "sharp" | "rounded" | "pill";
  layout: Block[];
}

const { name, description, buttonStyle = "sharp", layout } = Astro.props;
---

<div class="lt-root">
  <div class="lt-inner container-box container-pad">
    {
      layout.map((block) => {
        if (block.type === "profiles") {
          const b = block as any;
          return (
            <section class="lt-block lt-block--profiles">
              <ProfileRow
                profiles={b.profiles}
                columns={b.columns}
                buttonStyle={buttonStyle}
              />
            </section>
          );
        }

        if (block.type === "links") {
          const b = block as any;
          return (
            <section class="lt-block lt-block--links">
              <LinkList links={b.links} buttonStyle={buttonStyle} />
            </section>
          );
        }

        if (block.type === "text") {
          const b = block as any;
          return (
            <div class="lt-block lt-section-label">
              <span>{b.content}</span>
            </div>
          );
        }

        if (block.type === "divider") {
          return <hr class="lt-divider" />;
        }

        return null;
      })
    }
  </div>
</div>

<style>
  .lt-root {
    display: flex;
    justify-content: center;
    width: 100%;
    font-family: var(--font, inherit);
    min-height: 100%;
  }

  .lt-inner {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .lt-block {
    width: 100%;
    min-width: 0;
  }

  .lt-block--profiles {
    margin-bottom: 1.2rem;
  }

  .lt-block--links {
    /* nothing extra */
  }

  .lt-section-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.25rem;
    margin-bottom: 0.1rem;
  }

  .lt-section-label span {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    opacity: 0.62;
    white-space: nowrap;
    font-family: "SF Mono", ui-monospace, monospace;
  }

  .lt-section-label::after {
    content: "";
    flex: 1;
    height: 1px;
    background: currentColor;
    opacity: 0.1;
  }

  .lt-divider {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    margin: 0.6rem 0;
  }

  @media (max-width: 420px) {
    .lt-inner {
      padding-inline: 0.9rem;
    }
  }
</style>
