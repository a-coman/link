---
/**
 * ProfileRow — renders a responsive grid of ProfileCards.
 * `columns` drives the CSS grid column count.
 */
import ProfileCard from "./ProfileCard.astro";

interface Social {
  platform: string;
  url: string;
  label?: string;
  icon?: string;
}

interface ProfileItem {
  name: string;
  description?: string;
  avatar?: string;
  socials?: Social[];
}

interface Props {
  profiles: ProfileItem[];
  columns?: number;
  buttonStyle?: "sharp" | "rounded" | "pill";
}

const { profiles, columns = 2, buttonStyle = "sharp" } = Astro.props;
const normalizedColumns = Math.min(Math.max(columns, 1), 4);
const colClass = `cols-${normalizedColumns}`;

const totalProfiles = profiles.length;
const lastRowRemainder = totalProfiles % normalizedColumns;
const hasIncompleteLastRow = lastRowRemainder > 0;
const firstLastRowIndex = totalProfiles - lastRowRemainder;
const lastRowStartTrack = hasIncompleteLastRow
  ? normalizedColumns - lastRowRemainder + 1
  : 1;
---

<div class={`profile-row ${colClass}`}>
  {
    profiles.map((p, idx) => (
      <div
        class={`profile-card-wrapper ${
          hasIncompleteLastRow && idx === firstLastRowIndex
            ? "last-row-start"
            : ""
        }`}
        style={
          hasIncompleteLastRow && idx === firstLastRowIndex
            ? `--last-row-start:${lastRowStartTrack};`
            : undefined
        }
      >
        <ProfileCard
          name={p.name}
          description={p.description}
          avatar={p.avatar}
          socials={p.socials}
          buttonStyle={buttonStyle}
        />
      </div>
    ))
  }
</div>

<style>
  .profile-row {
    --profile-row-gap: clamp(0.55rem, 3vw, 1.1rem);
    display: grid;
    gap: var(--profile-row-gap);
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
  }

  .profile-card-wrapper {
    display: flex;
    justify-content: center;
    min-width: 0;
    width: 100%;
    grid-column: span 2;
  }

  .profile-row.cols-1 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .profile-row.cols-2 {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .profile-row.cols-3 {
    grid-template-columns: repeat(6, minmax(0, 1fr));
  }

  .profile-row.cols-4 {
    grid-template-columns: repeat(8, minmax(0, 1fr));
  }

  .profile-row.cols-1 .profile-card-wrapper,
  .profile-row.cols-2 .profile-card-wrapper,
  .profile-row.cols-3 .profile-card-wrapper,
  .profile-row.cols-4 .profile-card-wrapper {
    min-width: 140px;
  }

  .profile-card-wrapper.last-row-start {
    grid-column: var(--last-row-start) / span 2;
  }

  @media (max-width: 480px) {
    .profile-row.cols-2,
    .profile-row.cols-3,
    .profile-row.cols-4 {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .profile-card-wrapper.last-row-start {
      grid-column: auto / span 2;
    }
  }

  @media (max-width: 299px) {
    .profile-row {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }

    .profile-card-wrapper {
      grid-column: span 2;
    }
  }
</style>
