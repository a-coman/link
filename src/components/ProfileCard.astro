---
/**
 * ProfileCard — renders a single profile.
 * Avatar images fall back gracefully to a ph:user icon if the src is missing/broken.
 * Borderless design — space-separated, typography-led.
 */
import { existsSync } from "node:fs";
import { Icon } from "astro-icon/components";
import SocialIcon from "./SocialIcon.astro";

interface Social {
  platform: string;
  url: string;
  label?: string;
  icon?: string;
}

interface Props {
  name: string;
  description?: string;
  avatar?: string;
  socials?: Social[];
  buttonStyle?: "sharp" | "rounded" | "pill";
}

const {
  name,
  description,
  avatar,
  socials,
  buttonStyle = "sharp",
} = Astro.props;

const avatarPath = avatar?.startsWith("/")
  ? avatar
  : avatar
    ? `/${avatar}`
    : undefined;
const hasLocalAvatar = avatarPath
  ? existsSync(new URL(`../../public${avatarPath}`, import.meta.url))
  : false;
---

<div class={`profile-card btn-${buttonStyle}`}>
  <div class="avatar-wrap">
    <span class="avatar-shell avatar-shell-base">
      {hasLocalAvatar && avatarPath && (
        <img
          src={avatarPath}
          alt=""
          class="avatar-img avatar-img-base"
          width="80"
          height="80"
          loading="lazy"
          decoding="async"
          onerror="this.style.display='none'"
        />
      )}
      <span class="avatar-icon" aria-hidden="true">
        <Icon name="ph:user" width={30} height={30} />
      </span>
    </span>
  </div>

  <div class="profile-info">
    <h2 class="profile-name">{name}</h2>
    {description && <p class="profile-desc">{description}</p>}

    {
      socials && socials.length > 0 && (
        <div class="socials">
          {socials.map((s) => (
            <SocialIcon platform={s.icon ?? s.platform} url={s.url} size={28} />
          ))}
        </div>
      )
    }
  </div>
</div>

<style>
  .profile-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    padding: 1.5rem 1rem 1.25rem;
    width: 100%;
    min-width: 0;
    position: relative;
    text-align: center;
    color: inherit;
    /* No border, no background — purely space-defined */
  }

  /* Border-radius still applies if avatar-shell or socials use it */
  .profile-card.btn-sharp {}
  .profile-card.btn-rounded {}
  .profile-card.btn-pill {}

  /* ── Avatar shell ──────────────────────────────── */
  .avatar-wrap {
    display: flex;
    justify-content: center;
    width: 100%;
    flex-shrink: 0;
  }

  .avatar-shell {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: inherit;
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .avatar-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.3;
    color: inherit;
    width: 100%;
    height: 100%;
  }

  /* ── Info ──────────────────────────────────────── */
  .profile-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    width: 100%;
    min-width: 0;
  }

  .profile-name {
    font-family: var(--font-display, 'IBM Plex Mono', monospace);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0;
    line-height: 1.2;
    word-break: break-word;
  }

  .profile-desc {
    margin: 0;
    line-height: 1.5;
    font-size: 0.74rem;
    opacity: 0.68;
    font-weight: 400;
    letter-spacing: 0.01em;
    font-family: var(--font-body, 'IBM Plex Sans', system-ui, sans-serif);
  }

  .socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    justify-content: center;
    margin-top: 0.5rem;
    min-width: 0;
    position: relative;
    z-index: 2;
  }

  /* ── Responsive ────────────────────────────────── */
  @media (max-width: 360px) {
    .avatar-shell {
      width: 60px;
      height: 60px;
    }
  }
</style>
