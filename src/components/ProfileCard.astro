---
/**
 * ProfileCard — renders a single profile.
 * Avatar images fall back gracefully to a ph:user icon if the src is missing/broken.
 */
import { existsSync } from "node:fs";
import { Icon } from "astro-icon/components";
import SocialIcon from "./SocialIcon.astro";

interface Social {
  platform: string;
  url: string;
  label?: string;
  icon?: string;
}

interface Props {
  name: string;
  description?: string;
  avatar?: string;
  socials?: Social[];
  buttonStyle?: "sharp" | "rounded" | "pill";
}

const {
  name,
  description,
  avatar,
  socials,
  buttonStyle = "sharp",
} = Astro.props;

const avatarPath = avatar?.startsWith("/")
  ? avatar
  : avatar
    ? `/${avatar}`
    : undefined;
const hasLocalAvatar = avatarPath
  ? existsSync(new URL(`../../public${avatarPath}`, import.meta.url))
  : false;
---

<div class={`profile-card btn-${buttonStyle}`}>
  <div class="avatar-wrap">
    <span class="avatar-shell avatar-shell-base">
      {hasLocalAvatar && avatarPath && (
        <img
          src={avatarPath}
          alt=""
          class="avatar-img avatar-img-base"
          width="80"
          height="80"
          loading="lazy"
          decoding="async"
          onerror="this.style.display='none'"
        />
      )}
      <span class="avatar-icon" aria-hidden="true">
        <Icon name="ph:user" width={34} height={34} />
      </span>
    </span>
  </div>

  <div class="profile-info">
    <h2 class="profile-name">{name}</h2>
    {description && <p class="profile-desc text-sub">{description}</p>}

    {
      socials && socials.length > 0 && (
        <div class="socials">
          {socials.map((s) => (
            <SocialIcon platform={s.icon ?? s.platform} url={s.url} size={32} />
          ))}
        </div>
      )
    }
  </div>
</div>

<style>
  .profile-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    padding: 1.5rem 0.75rem 1.25rem 0.75rem;
    width: 100%;
    min-width: 0;
    position: relative;
    text-align: center;
    color: inherit;
    
    /* Card style */
    border: 1px solid var(--card-border);
    background: var(--card-bg);
  }

  /* Border-radius variants */
  .profile-card.btn-sharp {
    border-radius: 0;
  }
  .profile-card.btn-rounded {
    border-radius: 8px;
  }
  .profile-card.btn-pill {
    border-radius: 1.5rem;
  }

  /* ── Avatar shell ──────────────────────────────── */
  .avatar-wrap {
    display: flex;
    justify-content: center;
    width: 100%;
    flex-shrink: 0;
    position: relative;
    z-index: 0; /* Behind hitbox */
  }

  .avatar-shell {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  /* Image sits on top of the icon; hidden via onerror if broken */
  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: inherit;
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  /* Icon sits below the image */
  .avatar-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.45;
    color: inherit;
    width: 100%;
    height: 100%;
  }

  /* ── Info ──────────────────────────────────────── */
  .profile-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    width: 100%;
    min-width: 0; /* allow text to wrap in tight columns */
    position: relative;
    z-index: 0;
  }

  .profile-name {
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    margin: 0;
    line-height: 1.2;
    word-break: break-word;
  }

  .profile-desc {
    margin: 0;
    line-height: 1.5;
    font-size: 0.9rem;
  }

  .socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    justify-content: center;
    margin-top: 0.6rem;
    min-width: 0;
    position: relative;
    z-index: 2; /* Sits above the hitbox logically and is clickable independently */
  }

  /* ── Responsive ────────────────────────────────── */
  @media (max-width: 360px) {
    .profile-card {
      padding: 1.1rem 0.5rem;
    }
    .avatar-shell {
      width: 68px;
      height: 68px;
    }
  }
</style>
