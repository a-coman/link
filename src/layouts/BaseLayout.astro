---
/**
 * BaseLayout — global HTML shell.
 * Handles meta tags, fonts, and css resets.
 */
import "../styles/shared.css";
import ThemeToggle from "../components/ThemeToggle.astro";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  theme?: {
    "background-light"?: string;
    "background-dark"?: string;
    "text-light"?: string;
    "text-dark"?: string;
    "accent-light"?: string;
    "accent-dark"?: string;
    "font-family"?: string;
  };
}

const { title, description, ogImage, theme } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const withBase = (pathname: string) =>
  `${baseUrl.replace(/\/$/, "/")}${pathname.replace(/^\//, "")}`;

const themeVars = theme
  ? [
      theme["background-light"]
        ? `--theme-background-light: ${theme["background-light"]}`
        : null,
      theme["background-dark"]
        ? `--theme-background-dark: ${theme["background-dark"]}`
        : null,
      theme["text-light"] ? `--theme-text-light: ${theme["text-light"]}` : null,
      theme["text-dark"] ? `--theme-text-dark: ${theme["text-dark"]}` : null,
      theme["accent-light"]
        ? `--theme-accent-light: ${theme["accent-light"]}`
        : null,
      theme["accent-dark"]
        ? `--theme-accent-dark: ${theme["accent-dark"]}`
        : null,
      theme["font-family"]
        ? `--font-display: ${theme["font-family"]}; --font-body: ${theme["font-family"]}`
        : null,
    ]
      .filter(Boolean)
      .join("; ")
  : undefined;

if (!title || !description) {
  throw new Error(
    `BaseLayout: 'title' and 'description' are strictly required for all pages. Please provide them.`,
  );
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="profile" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <!-- <link rel="icon" href="/favicon.ico" /> -->

    <!-- Fonts: IBM Plex Mono (display) + IBM Plex Sans (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Theme Initialization Script (Prevents FOUC) -->
    <script is:inline>
      (() => {
        var e = localStorage.getItem("theme");
        e
          ? "light" === e &&
            document.documentElement.setAttribute("data-theme", "light")
          : window.matchMedia("(prefers-color-scheme: light)").matches &&
            document.documentElement.setAttribute("data-theme", "light");
      })();
    </script>

    <!-- Global reset -->
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html,
      body {
        height: 100%;
        overflow-x: hidden;
      }

      :root {
        --font-display: "IBM Plex Mono", ui-monospace, monospace;
        --font-body: "IBM Plex Sans", system-ui, sans-serif;
      }

      :global(body) {
        background: var(--theme-background-dark, #0a0a0a);
        color: var(--theme-text-dark, #ededeb);
        font-family: var(--font-body);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        line-height: 1.55;
        min-width: 0;
        transition:
          background 0.25s ease,
          color 0.25s ease;
      }

      :global(html[data-theme="light"] body) {
        background: #f7f6f3;
        background: var(--theme-background-light, #f7f6f3);
        color: var(--theme-text-light, #0f0f0f);
      }

      img,
      video {
        max-width: 100%;
        height: auto;
      }

      a {
        color: inherit;
      }

      /* Grain texture overlay */
      :global(body::after) {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 9999;
        opacity: 0.025;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
        background-size: 180px 180px;
      }

      /* Entrance animation */
      @keyframes pageIn {
        from {
          opacity: 0;
          transform: translateY(14px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      main {
        display: flex;
        justify-content: center;
        width: 100%;
        min-width: 0;
        animation: pageIn 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
      }
    </style>
  </head>
  <body style={themeVars || undefined}>
    <main>
      <slot />
    </main>
    <ThemeToggle />
  </body>
</html>
